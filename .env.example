# Runtime profile. Production requires both values to be production.
NODE_ENV=development
DEPLOYMENT_PROFILE=local
LOG_LEVEL=info

# Public topology. NEXT_PUBLIC_API_BASE_URL is the only browser-exposed value.
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
ALLOWED_WEB_ORIGINS=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
API_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000

# Server-only data services.
DATABASE_URL=postgresql://nimbus:nimbus@localhost:5432/nimbus?schema=public
REDIS_URL=redis://localhost:6379

# Local MinIO aliases. Production should use the generic S3_* variables below.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=nimbus
MINIO_SECRET_KEY=nimbus-secret
MINIO_BUCKET=nimbus-local
MINIO_REGION=us-east-1

# Production-compatible S3/R2 settings. Never prefix credentials with NEXT_PUBLIC_.
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=replace-with-provider-access-key
# S3_SECRET_ACCESS_KEY=replace-with-provider-secret
# S3_BUCKET=nimbus-production
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=false

# Local browser identity. These headers are ignored when NODE_ENV or profile is production.
AUTH_MODE=dev
DEV_AUTH_ENABLED=true
WEB_DEV_AUTH_USER=nimbus-demo
WEB_DEV_AUTH_EMAIL=demo.owner@example.test
WEB_DEV_AUTH_NAME=Nimbus Demo

# Production Auth.js and short-lived web-to-API tokens. Use independent random secrets.
# AUTH_MODE=authjs
# DEV_AUTH_ENABLED=false
# AUTH_SECRET=replace-with-at-least-32-random-characters
# AUTH_GITHUB_ID=replace-with-github-oauth-client-id
# AUTH_GITHUB_SECRET=replace-with-github-oauth-client-secret
# AUTH_TRUST_HOST=true
# AUTH_SESSION_MAX_AGE_SECONDS=86400
# API_AUTH_SECRET=replace-with-a-different-32-character-random-secret
API_AUTH_ISSUER=nimbus-web
API_AUTH_AUDIENCE=nimbus-api
API_ACCESS_TOKEN_TTL_SECONDS=300

# Upload and signed-URL bounds.
MAX_FOLDER_DEPTH=32
MAX_FILE_SIZE_BYTES=5368709120
SIGNED_UPLOAD_URL_TTL_SECONDS=900
SIGNED_DOWNLOAD_URL_TTL_SECONDS=300
UPLOAD_SESSION_TTL_SECONDS=86400
MULTIPART_UPLOAD_THRESHOLD_BYTES=67108864
MULTIPART_CHUNK_SIZE_BYTES=8388608

# Redis-backed API rate limits per 60-second window.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PUBLIC_MAX=60
RATE_LIMIT_SEARCH_MAX=120
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_SIGNED_URL_MAX=120

# Worker safety bounds and concurrency.
THUMBNAIL_MAX_INPUT_BYTES=20971520
THUMBNAIL_MAX_PIXEL_COUNT=40000000
THUMBNAIL_MAX_WIDTH=12000
THUMBNAIL_MAX_HEIGHT=12000
THUMBNAIL_OUTPUT_WIDTH=320
THUMBNAIL_OUTPUT_HEIGHT=320
THUMBNAIL_PROCESSING_TIMEOUT_MS=15000
UPLOAD_FINALIZATION_CONCURRENCY=2
METADATA_INDEXING_CONCURRENCY=5
THUMBNAIL_GENERATION_CONCURRENCY=2
OBJECT_CLEANUP_CONCURRENCY=3

# Demo reset is destructive only for the three fixed synthetic users and their objects.
DEMO_MODE=false
DEMO_RESET_ENABLED=false
