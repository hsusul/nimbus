NODE_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=4000
WEB_PORT=3000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WEB_DEV_AUTH_USER=nimbus-demo
WEB_DEV_AUTH_EMAIL=nimbus-demo@nimbus.local
WEB_DEV_AUTH_NAME=Nimbus Demo
MAX_FOLDER_DEPTH=32
MAX_FILE_SIZE_BYTES=5368709120
SIGNED_UPLOAD_URL_TTL_SECONDS=900
SIGNED_DOWNLOAD_URL_TTL_SECONDS=300
UPLOAD_SESSION_TTL_SECONDS=86400
MULTIPART_UPLOAD_THRESHOLD_BYTES=67108864
MULTIPART_CHUNK_SIZE_BYTES=8388608
THUMBNAIL_MAX_INPUT_BYTES=20971520
THUMBNAIL_MAX_PIXEL_COUNT=40000000
THUMBNAIL_MAX_WIDTH=12000
THUMBNAIL_MAX_HEIGHT=12000
THUMBNAIL_OUTPUT_WIDTH=320
THUMBNAIL_OUTPUT_HEIGHT=320
THUMBNAIL_PROCESSING_TIMEOUT_MS=15000
METADATA_INDEXING_CONCURRENCY=5
THUMBNAIL_GENERATION_CONCURRENCY=2
OBJECT_CLEANUP_CONCURRENCY=3

DATABASE_URL=postgresql://nimbus:nimbus@localhost:5432/nimbus?schema=public
REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=nimbus
MINIO_SECRET_KEY=nimbus-secret
MINIO_BUCKET=nimbus-local
MINIO_REGION=us-east-1

AUTH_MODE=dev
DEV_AUTH_ENABLED=true
