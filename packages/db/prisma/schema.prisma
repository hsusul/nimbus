generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  authSubject       String    @unique @map("auth_subject")
  email             String    @unique
  displayName       String?   @map("display_name")
  avatarUrl         String?   @map("avatar_url")
  status            String    @default("active")
  storageQuotaBytes BigInt    @default(5368709120) @map("storage_quota_bytes")
  storageUsedBytes  BigInt    @default(0) @map("storage_used_bytes")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  folders             Folder[]        @relation("FolderOwner")
  files               File[]          @relation("FileOwner")
  auditLogs           AuditLog[]      @relation("AuditActor")
  uploadSessions      UploadSession[] @relation("UploadSessionOwner")
  uploadChunks        UploadChunk[]   @relation("UploadChunkOwner")
  createdFileVersions FileVersion[]   @relation("FileVersionCreator")
  sharesCreated       Share[]         @relation("ShareCreator")
  sharesReceived      Share[]         @relation("ShareGrantee")
  shareLinksCreated   ShareLink[]     @relation("ShareLinkCreator")
  backgroundJobs      BackgroundJob[] @relation("BackgroundJobOwner")
  thumbnails          Thumbnail[]     @relation("ThumbnailOwner")
  apiKeys             ApiKey[]        @relation("ApiKeyOwner")

  @@index([status])
  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  ownerId    String    @map("owner_user_id")
  name       String
  prefix     String    @unique
  keyHash    String    @unique @map("key_hash")
  scopes     String[]
  status     String    @default("active")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  owner User @relation("ApiKeyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@index([expiresAt])
  @@map("api_keys")
}

model Folder {
  id              String                   @id @default(cuid())
  ownerId         String                   @map("owner_id")
  parentFolderId  String?                  @map("parent_folder_id")
  name            String
  normalizedName  String                   @map("normalized_name")
  pathCache       String?                  @map("path_cache")
  depth           Int                      @default(0)
  status          String                   @default("active")
  deletedAt       DateTime?                @map("deleted_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  searchDocument  String                   @default("") @map("search_document")
  searchIndexedAt DateTime?                @map("search_indexed_at")
  searchVector    Unsupported("tsvector")? @map("search_vector")

  owner          User            @relation("FolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  parentFolder   Folder?         @relation("FolderTree", fields: [parentFolderId], references: [id], onDelete: Restrict)
  childFolders   Folder[]        @relation("FolderTree")
  files          File[]
  uploadSessions UploadSession[]

  @@index([ownerId, parentFolderId])
  @@index([ownerId, deletedAt])
  @@index([parentFolderId])
  @@map("folders")
}

model File {
  id               String                   @id @default(cuid())
  ownerId          String                   @map("owner_id")
  folderId         String                   @map("folder_id")
  name             String
  normalizedName   String                   @map("normalized_name")
  extension        String?
  mimeType         String?                  @map("mime_type")
  status           String                   @default("active")
  sizeBytes        BigInt                   @default(0) @map("size_bytes")
  contentHash      String?                  @map("content_hash")
  currentVersionId String?                  @map("current_version_id")
  deletedAt        DateTime?                @map("deleted_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  searchDocument   String                   @default("") @map("search_document")
  searchIndexedAt  DateTime?                @map("search_indexed_at")
  searchVector     Unsupported("tsvector")? @map("search_vector")

  owner          User            @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  folder         Folder          @relation(fields: [folderId], references: [id], onDelete: Restrict)
  versions       FileVersion[]   @relation("FileVersions")
  currentVersion FileVersion?    @relation("CurrentFileVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  uploadSessions UploadSession[] @relation("UploadSessionTargetFile")
  thumbnails     Thumbnail[]

  @@index([ownerId, folderId])
  @@index([ownerId, deletedAt])
  @@index([folderId])
  @@index([currentVersionId])
  @@map("files")
}

model UploadSession {
  id                String    @id @default(cuid())
  ownerId           String    @map("owner_id")
  targetFolderId    String    @map("target_folder_id")
  targetFileId      String?   @map("target_file_id")
  plannedVersionId  String    @map("planned_version_id")
  uploadMode        String    @default("new_file") @map("upload_mode")
  filename          String
  mimeType          String    @map("mime_type")
  totalSizeBytes    BigInt    @map("total_size_bytes")
  expectedSha256    String?   @map("expected_sha256")
  finalObjectKey    String    @map("final_object_key")
  bucket            String
  uploadType        String    @default("single_part") @map("upload_type")
  multipartUploadId String?   @map("multipart_upload_id")
  chunkSizeBytes    BigInt?   @map("chunk_size_bytes")
  receivedBytes     BigInt    @default(0) @map("received_bytes")
  status            String    @default("created")
  correlationId     String?   @map("correlation_id")
  expiresAt         DateTime  @map("expires_at")
  completedAt       DateTime? @map("completed_at")
  failureReason     String?   @map("failure_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  owner        User          @relation("UploadSessionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  targetFolder Folder        @relation(fields: [targetFolderId], references: [id], onDelete: Restrict)
  targetFile   File?         @relation("UploadSessionTargetFile", fields: [targetFileId], references: [id], onDelete: SetNull)
  fileVersion  FileVersion?
  uploadChunks UploadChunk[]

  @@index([ownerId, status])
  @@index([targetFolderId])
  @@index([targetFileId])
  @@index([expiresAt])
  @@index([correlationId])
  @@index([uploadType])
  @@map("upload_sessions")
}

model UploadChunk {
  id              String   @id @default(cuid())
  uploadSessionId String   @map("upload_session_id")
  ownerId         String   @map("owner_id")
  partNumber      Int      @map("part_number")
  sizeBytes       BigInt   @map("size_bytes")
  sha256          String?
  etag            String
  status          String   @default("uploaded")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  uploadSession UploadSession @relation(fields: [uploadSessionId], references: [id], onDelete: Cascade)
  owner         User          @relation("UploadChunkOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([uploadSessionId, partNumber])
  @@index([uploadSessionId])
  @@index([uploadSessionId, status])
  @@index([ownerId])
  @@map("upload_chunks")
}

model BackgroundJob {
  id            String    @id @default(cuid())
  ownerId       String    @map("owner_id")
  queueName     String    @map("queue_name")
  bullmqJobId   String?   @map("bullmq_job_id")
  resourceType  String    @map("resource_type")
  resourceId    String    @map("resource_id")
  status        String    @default("queued")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3) @map("max_attempts")
  lastError     String?   @map("last_error")
  failureCode   String?   @map("failure_code")
  correlationId String?   @map("correlation_id")
  dedupeKey     String?   @unique @map("dedupe_key")
  createdAt     DateTime  @default(now()) @map("created_at")
  startedAt     DateTime? @map("started_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  owner User @relation("BackgroundJobOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([queueName, status])
  @@index([resourceType, resourceId])
  @@index([ownerId, createdAt])
  @@index([ownerId, queueName, status, createdAt])
  @@index([correlationId])
  @@index([createdAt])
  @@map("background_jobs")
}

model FileVersion {
  id               String   @id @default(cuid())
  fileId           String   @map("file_id")
  versionNumber    Int      @map("version_number")
  storageProvider  String   @map("storage_provider")
  bucket           String
  objectKey        String   @map("object_key")
  sizeBytes        BigInt   @map("size_bytes")
  sha256           String?
  etag             String?
  mimeType         String   @map("mime_type")
  uploadSessionId  String   @unique @map("upload_session_id")
  createdById      String   @map("created_by_id")
  processingStatus String   @default("pending") @map("processing_status")
  createdAt        DateTime @default(now()) @map("created_at")

  file            File          @relation("FileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  currentForFiles File[]        @relation("CurrentFileVersion")
  uploadSession   UploadSession @relation(fields: [uploadSessionId], references: [id], onDelete: Restrict)
  createdBy       User          @relation("FileVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  thumbnail       Thumbnail?

  @@unique([fileId, versionNumber])
  @@index([fileId, createdAt])
  @@index([createdById])
  @@index([processingStatus])
  @@map("file_versions")
}

model Thumbnail {
  id            String    @id @default(cuid())
  ownerId       String    @map("owner_id")
  fileId        String    @map("file_id")
  fileVersionId String    @unique @map("file_version_id")
  status        String    @default("pending")
  bucket        String?
  objectKey     String?   @map("object_key")
  mimeType      String    @default("image/webp") @map("mime_type")
  width         Int?
  height        Int?
  sizeBytes     BigInt?   @map("size_bytes")
  failureCode   String?   @map("failure_code")
  completedAt   DateTime? @map("completed_at")
  failedAt      DateTime? @map("failed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  owner       User        @relation("ThumbnailOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  file        File        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileVersion FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@index([fileId, status])
  @@index([status, createdAt])
  @@map("thumbnails")
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String   @map("actor_user_id")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String   @map("resource_id")
  targetUserId  String?  @map("target_user_id")
  requestId     String?  @map("request_id")
  correlationId String?  @map("correlation_id")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  metadataJson  Json?    @map("metadata_json")
  createdAt     DateTime @default(now()) @map("created_at")

  actor User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

model Share {
  id            String    @id @default(cuid())
  resourceType  String    @map("resource_type")
  resourceId    String    @map("resource_id")
  granteeUserId String    @map("grantee_user_id")
  role          String
  createdById   String    @map("created_by_id")
  expiresAt     DateTime? @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  grantee   User @relation("ShareGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  createdBy User @relation("ShareCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([resourceType, resourceId])
  @@index([granteeUserId, revokedAt])
  @@index([createdById, revokedAt])
  @@map("shares")
}

model ShareLink {
  id           String    @id @default(cuid())
  resourceType String    @map("resource_type")
  resourceId   String    @map("resource_id")
  tokenHash    String    @unique @map("token_hash")
  role         String    @default("viewer")
  createdById  String    @map("created_by_id")
  expiresAt    DateTime? @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  useCount     Int       @default(0) @map("use_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdBy User @relation("ShareLinkCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([resourceType, resourceId])
  @@index([createdById, revokedAt])
  @@index([expiresAt])
  @@map("share_links")
}
