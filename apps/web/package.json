{
  "name": "@nimbus/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port ${WEB_PORT:-3000}",
    "build": "next build",
    "start": "next start --port ${WEB_PORT:-3000}",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run test",
    "test:watch": "vitest test",
    "test:e2e": "docker compose -f ../../docker-compose.yml run --rm minio-init && pnpm --dir ../.. demo:seed && playwright test",
    "test:e2e:production": "playwright test --config=playwright.production.config.ts"
  },
  "dependencies": {
    "@nimbus/auth": "workspace:*",
    "@nimbus/config": "workspace:*",
    "@nimbus/contracts": "workspace:*",
    "lucide-react": "^1.23.0",
    "next": "^15.4.2",
    "next-auth": "4.24.14",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
